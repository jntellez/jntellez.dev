---
import { Icon } from "astro-icon/components";

interface Props {
  href: string;
  class?: string;
  download?: boolean;
}

const { href, class: className = "", download, ...rest } = Astro.props;
---

<a
  href={href}
  target={download ? undefined : "_blank"}
  rel={download ? undefined : "noopener noreferrer"}
  download={download || undefined}
  class:list={[
    "inline-flex items-center gap-1 hover:underline dark:hover:text-blue-700 hover:text-blue-600",
    className,
  ]}
  {...rest}
>
  <slot />
  <Icon name="lucide:arrow-up-right" size={14} />
</a>
